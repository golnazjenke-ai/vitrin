{
    "name": "chortke/platform",
    "description": "پلتفرم کسب درآمد آنلاین چرتکه",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "phpmailer/phpmailer": "^7.0",
        "ext-pdo": "*"
    },
    "autoload": {
        "psr-4": {
            "Core\\": "core/",
            "App\\": "app/"
        },
        "files": [
            "core/Exceptions.php",
            "helpers/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true
    },
    "require-dev": {
        "phpunit/phpunit": "8.*",
        "mockery/mockery": "^1.6"
    },
    "scripts": {
        "security-check": "composer audit"
    }
}
